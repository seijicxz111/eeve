{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "eeve": ["./src/index.ts"],
      "eeve/styles.css": ["./src/styles/globals.css"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "src",
    "site",
    "tests",
    ".storybook/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "eslint.config.js"
  ],
  "references": []
}
