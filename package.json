{
  "name": "eeve-ui-components",
  "version": "0.1.0",
  "description": "A typed, accessible React component library and design-system foundation.",
  "type": "module",
  "license": "MIT",
  "author": "Seiji CXZ",
  "homepage": "https://your-storybook-domain.example",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seijicxz111/eeve.git"
  },
  "bugs": {
    "url": "https://github.com/seijicxz111/eeve/issues"
  },
  "keywords": [
    "react",
    "components",
    "design-system",
    "typescript",
    "storybook",
    "tailwindcss",
    "accessibility"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./tokens.css": "./dist/tokens.css",
    "./themes.css": "./dist/themes.css",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "storybook": "storybook dev -p 6006",
    "build": "vite build --mode library && node scripts/copy-styles.mjs",
    "build:storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:storybook": "npm run build:storybook && concurrently -k -s first -n serve,test \"http-server storybook-static -p 6006 -c-1\" \"wait-on tcp:6006 && test-storybook --url http://127.0.0.1:6006\"",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run lint && npm run typecheck && npm run test && npm run build && changeset publish",
    "publint": "publint",
    "audit": "npm audit --audit-level=high"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-avatar": "^1.1.17",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.9",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slider": "^1.3.7",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.2.7",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-themes": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "http-server": "^14.1.1",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.2.7",
    "playwright": "^1.61.1",
    "prettier": "^3.9.0",
    "publint": "^0.3.21",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ],
    "*.{css,md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
